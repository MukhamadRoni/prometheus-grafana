# ==============================================
# Docker Monitoring Stack - Environment Variables
# ==============================================
# Salin file ini menjadi .env dan isi dengan nilai sebenarnya:
#   cp .env.example .env
# ==============================================

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=GANTI_PASSWORD_INI
GRAFANA_PORT=4000
GRAFANA_ALLOW_SIGN_UP=false

# --- Prometheus ---
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=30d

# --- Node Exporter ---
NODE_EXPORTER_PORT=9100

# --- Blackbox Exporter ---
BLACKBOX_EXPORTER_PORT=9115

# --- Target Aplikasi Web (untuk TCP Probing) ---
TARGET_HOST=103.253.244.101
TARGET_PORT_1=8081
TARGET_PORT_2=8082
